# Copy this file to .env and fill in real values.
# On Railway: set these in Project > Variables instead of using a .env file.

# Supabase — Project Settings > Database > Connection string (URI), use the "pooler" connection if available
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Anthropic — console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Search provider for Tier 3 — brave.com/search/api (free tier available)
SEARCH_PROVIDER=brave
BRAVE_API_KEY=xxxxxxxx

# Tuning (optional, defaults shown)
TIER1_CONCURRENCY=10
TIER1_TIMEOUT_SECONDS=10
TIER3_BATCH_SIZE=20
